# 复制为 .env 后填入真实值（.env 已被 git 忽略，不会上传）
DASHSCOPE_API_KEY=

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USERNAME=
MILVUS_PASSWORD=

# Prometheus
PROMETHEUS_BASE_URL=http://localhost:9090

# 腾讯云 CLS（mock-enabled=false 时需要）
CLS_REGION=ap-guangzhou
CLS_LOGSET_ID=
CLS_TOPIC_SYSTEM_METRICS=

# 腾讯云 MCP（启用 spring.ai.mcp 时需要）
TENCENT_MCP_URL=https://mcp-api.tencent-cloud.com
TENCENT_MCP_SSE_ENDPOINT=
